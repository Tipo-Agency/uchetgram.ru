# Скопируйте в .env.local (не коммить секреты).

# POST тело — JSON как в create_deal (camelCase). По умолчанию:
#   /api/deals (тот же origin; в проде nginx проксирует на https://tipa.uchetgram.ru/api/deals).
# Прямой URL на tipa из браузера не работает из‑за CORS — только прокси или исправление CORS на tipa.
# VITE_LEAD_SUBMIT_URL=https://example.com/api/deals

# Опционально: привязка к воронке и источнику в CRM tipa (UUID из админки)
# VITE_TIPA_FUNNEL_ID=
# VITE_TIPA_SOURCE_ID=

# Уведомления в MAX и Telegram (опционально)
# VITE_TELEGRAM_BOT_TOKEN=
# VITE_TELEGRAM_CHAT_ID=
